{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GlossReader",
  "version": "1.1.2",
  "identifier": "com.tongzhao.glossreader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GlossReader",
        "width": 1200,
        "height": 900
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/glossreader-icon-32.png",
      "icons/glossreader-icon-128.png",
      "icons/glossreader-icon-128@2x.png",
      "icons/glossreader-icon.icns",
      "icons/glossreader-icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["pdf"],
        "name": "PDF Document",
        "description": "PDF document",
        "role": "Viewer",
        "mimeType": "application/pdf"
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZFREMwMzUyM0NFNTVEQjUKUldTMVhlVThVZ1BjYmkyTjdJeFNXaW8vSkUxRis5bm94QllZTERtdm0vQlNRanhoWW83VXlYcFEK",
      "endpoints": [
        "https://github.com/Tongzhao9417/GlossReader/releases/latest/download/latest.json"
      ]
    }
  }
}
